# ============================================================
# Order Exception Agent — Environment Variables
# cp .env.example .env  then fill in your values
# Never commit .env to version control
# ============================================================

# Shopify (production store)
SHOPIFY_SHOP_DOMAIN=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxx
SHOPIFY_WEBHOOK_SECRET=your_webhook_hmac_secret
SHOPIFY_API_VERSION=2024-01

# Shopify Dev Store (used when SHOPIFY_SANDBOX_MODE=true)
SHOPIFY_SANDBOX_MODE=false
SHOPIFY_DEV_STORE_DOMAIN=your-dev-store.myshopify.com
SHOPIFY_DEV_ACCESS_TOKEN=shpat_dev_xxxxxxxxxxxx

# Anthropic
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx
AGENT_MODEL=claude-sonnet-4-6

# Redis
REDIS_URL=redis://redis:6379/0

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://agent_user:secret@postgres:5432/order_exception_agent

# Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
SLACK_DEFAULT_CHANNEL=#ops-alerts

# 3PL
THREPL_WEBHOOK_URL=https://your-3pl.example.com/api/webhooks/shopify
THREPL_API_KEY=3pl_api_key_here

# LangFuse tracing (optional — leave blank to disable)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_ENABLED=false

# Sentry error monitoring (optional — leave blank to disable)
SENTRY_DSN=

# Agent behaviour
# "live" = full automation | "shadow" = log-only, skip all Shopify mutations
AGENT_MODE=shadow
# Orders above this USD total bypass automation and require manual operator review
HIGH_VALUE_REVIEW_THRESHOLD_USD=500.0

# Admin API (optional — leave blank to disable auth on /api/admin/* endpoints)
ADMIN_API_KEY=

# App
APP_ENV=production
LOG_LEVEL=INFO
PORT=8000
